{
  "name": "Dark Pur DEF",
  "dark": true,
  "author": "reflectline",
  "editorScheme": "/themes/DARK_PUR.xml",
  
  "colors": {
    "$selectionBackgroundAccent": "#5c16c5",
    "$selectionBackground": "#343436",
    "$selectionBackgroundInactive": "#2d2d2e",
    "$selectionUnderline": "#5c16c5",
    "$selectionUnderlineInactive": "#444445",
    "$selectionForeground": "#ffffff",
    "$selectionForegroundInactive": "#ffffff",
    "$controlBorder": "#414142",
    "$border": "#2d2d2e",
    "$separator": "#2d2d2e",
    "$controlFocus": "#9147ff",
    "$popupBorder": "#2f2f30",
    "$toolWindowBackground": "#1e1e1f",
    "$panelBackground": "#232324",
    "$regularForeground": "#dedee3",
    "$mutedForeground": "#b0b0b8",
    "$disabledForeground": "#6d6d70",
    "$textInputBackground": "#343436",
    "$textInputBackgroundDarker": "#2d2d2e",
    "$tabBackgroundSelected": "#2d2d2e",
    "$linkRegular": "#797DD6",
    "$linkAccented": "#797DD6",
    "$buttonBackground": "#454547",
    "$buttonBackgroundDarker": "#3e3e40",
    "$notificationBackground": "#2a2a2b",
    "$notificationBorder": "#2b2b2b",
    "$notificationForeground": "#f7f7f8",
    "$validationErrorBackground": "#592624",
    "$validationErrorBorder": "#753937",
    "$validationErrorForeground": "#FF9794",
    "$validationErrorFocus": "#DB5860A0",
    "$validationErrorFocusInactive": "#DB586060",
    "$validationWarningBackground": "#523911",
    "$validationWarningBorder": "#6C4F20",
    "$validationWarningForeground": "#EDBA68",
    "$validationWarningFocus": "#DE971FA0",
    "$validationWarningFocusInactive": "#DE971F60",
    "$validationInformativeBackground": "#0c5d5d",
    "$validationInformativeBorder": "#226868",
    "$validationInformativeForeground": "#61EDED",
    "$speedSearchBackground": "#451093",
    "$speedSearchMatchBackground": "#dedee3",
    "$searchMatchForeground": "#fcfaff",
    "$iconGrayRegular": "#A5A5AB",
    "$iconGrayMuted": "#A5A5ABB2",
    "$iconGrayDisabled": "#A5A5AB66",
    
    "Background": "#161617",
    "Foreground": "#e6e5e9",
    "Accent": "#5c16c5",
    "Link": "#9147ff",
    "Notification": "#330c6e"
  },
  
  "ui": {
    "*": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "selectionBackground": "$selectionBackground",
      "selectionForeground": "$selectionForeground",
      "selectionInactiveBackground": "$selectionBackgroundInactive",
      "selectionBackgroundInactive": "$selectionBackgroundInactive",
      "selectionInactiveForeground": "$selectionForegroundInactive",
      "selectionForegroundInactive": "$selectionForegroundInactive"
    },
    
    "Panel": {
      "background": "$panelBackground",
      "foreground": "$regularForeground"
    },
    
    "Borders": {
      "color": "$border",
      "ContrastBorderColor": "$border"
    },
    
    "NavBar": {
      "borderColor": "$border"
    },
    
    "StatusBar": {
      "borderColor": "$border"
    },
    
    "SearchEverywhere": {
      "Header.background": "$panelBackground",
      "Tab": {
        "selectedBackground": "$tabBackgroundSelected",
        "selectedForeground": "$selectionForeground"
      },
      "SearchField": {
        "background": "$textInputBackgroundDarker",
        "borderColor": "$textInputBackgroundDarker",
        "infoForeground": "$disabledForeground"
      },
      "List": {
        "separatorForeground": "$mutedForeground",
        "separatorColor": "$border"
      },
      "Advertiser": {
        "background": "$panelBackground",
        "foreground": "$mutedForeground"
      }
    },
    
    "SearchMatch": {
      "startBackground": "$speedSearchMatchBackground",
      "endBackground": "$speedSearchMatchBackground"
    },
    
    "SpeedSearch": {
      "background": "$speedSearchBackground",
      "borderColor": "$speedSearchBackground",
      "foreground": "$regularForeground",
      "errorForeground": "#ff9393"
    },
    
    "DefaultTabs": {
      "background": "$panelBackground",
      "hoverBackground": "$tabBackgroundSelected",
      "underlineColor": "$selectionUnderline",
      "inactiveUnderlineColor": "$selectionUnderlineInactive",
      "underlinedTabBackground": "$tabBackgroundSelected"
    },
    
    "EditorTabs": {
      "borderColor": "$border",
      "background": "$panelBackground",
      "underlineColor": "$selectionUnderline",
      "inactiveUnderlineColor": "$selectionUnderlineInactive",
      "underlineHeight": 2,
      "underlinedTabBackground": "$toolWindowBackground"
    },
    
    "ToolWindow": {
      "Button": {
        "selectedBackground": "$selectionBackgroundInactive",
        "selectedForeground": "$regularForeground",
        "hoverBackground": "$tabBackgroundSelected"
      },
      "Header": {
        "borderColor": "$border",
        "background": "$panelBackground",
        "inactiveBackground": "$panelBackground"
      },
      "HeaderTab": {
        "selectedInactiveBackground": "$panelBackground",
        "hoverBackground": "$tabBackgroundSelected",
        "hoverInactiveBackground": "$tabBackgroundSelected"
      }
    },
    
    "Plugins": {
      "background": "$toolWindowBackground",
      "lightSelectionBackground": "$selectionBackground",
      "hoverBackground": "$selectionBackgroundInactive",
      "SectionHeader": {
        "background": "$panelBackground",
        "foreground": "$regularForeground"
      },
      "Tab": {
        "selectedBackground": "$toolWindowBackground",
        "selectedForeground": "$regularForeground",
        "hoverBackground": "$tabBackgroundSelected"
      },
      "SearchField": {
        "background": "$textInputBackgroundDarker",
        "borderColor": "$panelBackground"
      },
      "Button": {
        "installFillBackground": "$buttonBackground",
        "installFillForeground": "$regularForeground",
        "installBackground": "$buttonBackground",
        "installBorderColor": "$border",
        "installForeground": "$regularForeground",
        "updateBackground": "$buttonBackground",
        "updateBorderColor": "$border",
        "updateForeground": "$regularForeground"
      },
      "tagBackground": "$panelBackground",
      "tagForeground": "$regularForeground"
    },
    
    "ScrollBar": {
      "background": "$panelBackground",
      "trackColor": "$panelBackground",
      "Mac.trackColor": "$panelBackground",
      "hoverTrackColor": "$panelBackground",
      "Mac.hoverTrackColor": "$panelBackground",
      "Transparent.trackColor": "#38383800",
      "Mac.Transparent.trackColor": "#38383800",
      "Transparent.hoverTrackColor": "#38383800",
      "Mac.Transparent.hoverTrackColor": "#38383800",
      "thumbBorderColor": "#66666940",
      "Mac.thumbBorderColor": "#66666940",
      "hoverThumbBorderColor": "#666669",
      "Mac.hoverThumbBorderColor": "#666669",
      "thumbColor": "#66666940",
      "Mac.thumbColor": "#66666940",
      "hoverThumbColor": "#666669",
      "Mac.hoverThumbColor": "#666669",
      "Transparent.thumbBorderColor": "#66666940",
      "Mac.Transparent.thumbBorderColor": "#66666940",
      "Transparent.hoverThumbBorderColor": "#666669",
      "Mac.Transparent.hoverThumbBorderColor": "#666669",
      "Transparent.thumbColor": "#66666940",
      "Mac.Transparent.thumbColor": "#66666940",
      "Transparent.hoverThumbColor": "#666669",
      "Mac.Transparent.hoverThumbColor": "#666669"
    },
    
    "CheckBox": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "disabledText": "$disabledForeground"
    },
    
    "RadioButton": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "disabledText": "$disabledForeground"
    },
    
    "Button": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "startBorderColor": "$controlBorder",
      "endBorderColor": "$controlBorder",
      "focusedBorderColor": "$controlFocus",
      "startBackground": "$buttonBackground",
      "endBackground": "$buttonBackground",
      "shadowWidth": 0,
      "default": {
        "foreground": "$selectionForeground",
        "startBorderColor": "$controlFocus",
        "endBorderColor": "$controlFocus",
        "focusedBorderColor": "$controlFocus",
        "startBackground": "$selectionBackgroundAccent",
        "endBackground": "$selectionBackgroundAccent",
        "focusColor": "$controlFocus"
      }
    },
    
    "ToggleButton": {
      "background": "$panelBackground",
      "borderColor": "$controlBorder",
      "foreground": "$regularForeground",
      "buttonColor": "$controlBorder",
      "onBackground": "$selectionBackgroundAccent",
      "onForeground": "$selectionForeground",
      "offBackground": "$buttonBackground",
      "offForeground": "$mutedForeground",
      "disabledText": "$disabledForeground"
    },
    
    "List": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "selectionBackground": "$selectionBackground",
      "selectionForeground": "$selectionForeground"
    },
    
    "Spinner": {
      "background": "$panelBackground"
    },
    
    "HelpTooltip": {
      "borderColor": "$border"
    },
    
    "ParameterInfo": {
      "background": "$panelBackground",
      "currentOverloadBackground": "$selectionBackground",
      "borderColor": "$popupBorder",
      "foreground": "$regularForeground",
      "currentParameterForeground": "$selectionForeground",
      "disabledForeground": "$disabledForeground",
      "infoForeground": "$regularForeground",
      "lineSeparatorColor": "$panelBackground"
    },
    
    "Menu": {
      "background": "$panelBackground",
      "borderColor": "$popupBorder",
      "foreground": "$regularForeground",
      "selectionForeground": "$selectionForeground",
      "separatorColor": "$separator",
      "acceleratorForeground": "$mutedForeground",
      "acceleratorSelectionForeground": "$selectionForeground",
      "disabledForeground": "$disabledForeground",
      "submenuPopupOffsetX": -1
    },
    
    "PopupMenu": {
      "borderWidth": 1,
      "leftBorderWith": 2,
      "rightBorderWith": 2,
      "borderInsets": "2,1,2,1",
      "background": "$panelBackground",
      "translucentBackground": "$panelBackground",
      "foreground": "$regularForeground"
    },
    
    "PopupMenuSeparator": {
      "height": 3,
      "stripeIndent": 1,
      "withToEdge": 0
    },
    
    "Popup": {
      "paintBorder": true,
      "borderColor": "$popupBorder",
      "inactiveBorderColor": "$popupBorder",
      "separatorColor": "$separator",
      "separatorForeground": "$mutedForeground",
      "Header": {
        "activeBackground": "$panelBackground",
        "inactiveBackground": "$panelBackground"
      },
      "Toolbar": {
        "background": "$panelBackground",
        "borderColor": "$toolWindowBackground"
      },
      "Advertiser": {
        "background": "$panelBackground",
        "borderColor": "$panelBackground",
        "foreground": "$mutedForeground"
      }
    },
    
    "MenuBar": {
      "foreground": "$regularForeground",
      "borderColor": "$panelBackground",
      "disabledBackground": "$panelBackground",
      "disabledForeground": "$disabledForeground"
    },
    
    "MenuItem": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "selectionBackground": "$selectionBackgroundAccent",
      "selectionForeground": "$selectionForeground",
      "acceleratorForeground": "$mutedForeground",
      "disabledForeground": "$disabledForeground"
    },
    
    "CheckBoxMenuItem": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "selectionBackground": "$selectionBackgroundAccent",
      "selectionForeground": "$selectionForeground",
      "acceleratorForeground": "$mutedForeground",
      "acceleratorSelectionForeground": "$selectionForeground",
      "disabledForeground": "$disabledForeground"
    },
    
    "RadioButtonMenuItem": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "selectionBackground": "$selectionBackgroundAccent",
      "selectionForeground": "$selectionForeground",
      "acceleratorForeground": "$mutedForeground",
      "acceleratorSelectionForeground": "$selectionForeground",
      "disabledForeground": "$disabledForeground"
    },
    
    "CompletionPopup": {
      "foreground": "$mutedForeground",
      "matchForeground": "$searchMatchForeground",
      "selectionBackground": "$selectionBackground",
      "selectionInactiveBackground": "$selectionBackground"
    },
    
    "Label": {
      "background": "$panelBackground",
      "foreground": "$regularForeground",
      "disabledForeground": "$disabledForeground",
      "infoForeground": "$mutedForeground"
    },
    
    "ComboBox": {
      "foreground": "$regularForeground",
      "background": "$panelBackground",
      "disabledForeground": "$disabledForeground",
      "nonEditableBackground": "$textInputBackground",
      "ArrowButton.background": "$textInputBackground",
      "ArrowButton.nonEditableBackground": "$textInputBackground",
      "ArrowButton.iconColor": "$iconGrayRegular",
      "ArrowButton.disabledIconColor": "$iconGrayDisabled"
    },
    
    "ComboBoxButton": {
      "background": "$textInputBackground"
    },
    
    "Tree": {
      "background": "$toolWindowBackground",
      "foreground": "$regularForeground",
      "modifiedItemForeground": "$linkAccented"
    },
    
    "Notification": {
      "background": "$notificationBackground",
      "borderColor": "$notificationBorder",
      "foreground": "$notificationForeground"
    },
    
    "Link": {
      "activeForeground": "$linkRegular",
      "hoverForeground": "$linkAccented",
      "pressedForeground": "$linkRegular",
      "visitedForeground": "$linkRegular"
    },
    
    "TextField": {
      "background": "$textInputBackgroundDarker",
      "foreground": "$regularForeground",
      "inactiveForeground": "$regularForeground"
    },
    
    "Table": {
      "background": "$toolWindowBackground",
      "foreground": "$regularForeground",
      "stripeColor": "$textInputBackground",
      "gridColor": "$panelBackground",
      "sortIconColor": "$mutedForeground",
      "lightSelectionBackground": "$selectionBackgroundAccent",
      "lightSelectionForeground": "$selectionForeground",
      "lightSelectionInactiveBackground": "$selectionBackgroundInactive",
      "lightSelectionInactiveForeground": "$selectionForegroundInactive"
    },
    
    "TableHeader": {
      "background": "$panelBackground",
      "foreground": "$mutedForeground",
      "cellBorder": "0,1,1,1",
      "separatorColor": "$border",
      "bottomSeparatorColor": "$panelBackground"
    },
    
    "Editor": {
      "background": "$toolWindowBackground",
      "foreground": "$regularForeground",
      "shortcutForeground": "$linkRegular"
    },
    
    "TabbedPane": {
      "background": "$panelBackground",
      "underlineColor": "$selectionUnderline",
      "disabledUnderlineColor": "$selectionUnderlineInactive",
      "contentAreaColor": "$border",
      "hoverColor": "$tabBackgroundSelected",
      "tabSelectionHeight": 3
    },
    
    "WelcomeScreen": {
      "background": "$panelBackground",
      "separatorColor": "$separator",
      "SidePanel.background": "$panelBackground",
      "Details.background": "$toolWindowBackground",
      "Projects": {
        "background": "$panelBackground",
        "actions": {
          "background": "$buttonBackgroundDarker"
        }
      }
    },
    
    "Group": {
      "separatorColor": "$separator"
    },
    
    "TitlePane": {
      "background": "$panelBackground",
      "inactiveBackground": "$panelBackground",
      "infoForeground": "$mutedForeground",
      "inactiveInfoForeground": "$disabledForeground"
    },
    
    "Separator.separatorColor": "$separator",
    
    "SidePanel.background": "$toolWindowBackground",
    
    "OptionPane.background": "$panelBackground"
  }
}