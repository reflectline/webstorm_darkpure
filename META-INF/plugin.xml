<idea-plugin>
    <id>com.send0xx.dark-pur</id>
    <name>Dark Pur DEF</name>
    <version>1.0.0</version>
    <vendor email="reflectline.dev@gmail.com" url="https://github.com/reflectline">reflectline</vendor>

    <description><![CDATA[
      Dark purple theme for JetBrains IDEs
    ]]></description>

    <change-notes><![CDATA[
      1.0 Initial release
    ]]></change-notes>

    <idea-version since-build="203.0"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <themeProvider 
            path="/themes/DARK_PUR.theme.json" 
            id="DarkPurTheme"/>
    </extensions>
</idea-plugin>